@{
    ViewData["Title"] = "Home Page";
}

<div class="container home-container">

    <!-- 🔥 HERO -->
    <div class="hero-section text-center">

        <h1 class="hero-title">
           Form Management System
        </h1>

        <p class="hero-subtitle">
            Manage Students & Employees with a modern experience
        </p>

        <div class="mt-4 d-flex gap-3 flex-wrap justify-content-center">
            <a asp-controller="Main" asp-action="Submit"
                   class="btn btn-modern btn-lg px-4">
                ➕ Create Record
            </a>

            <a asp-controller="Dashboard" asp-action="Index"
                   class="btn btn-outline-light btn-lg px-4">
                📊 View Data
            </a>
        </div>

    </div>

    <!-- 🔹 CARDS -->
    <div class="row mt-5 g-4">

        <div class="col-md-4">
            <div class="feature-card glass text-center p-4 h-100">
                <div class="icon">👨‍🎓</div>
                <h4>Students</h4>
                <p>Add & manage student records</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card glass text-center p-4 h-100">
                <div class="icon">👨‍💼</div>
                <h4>Employees</h4>
                <p>Manage employee data easily</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card glass text-center p-4 h-100">
                <div class="icon">📊</div>
                <h4>Dashboard</h4>
                <p>See all saved records</p>
            </div>
        </div>

    </div>

</div>

<style>

    /* ✅ IMPORTANT FIX */
    .home-container {
        position: relative;
        z-index: 2; /* 👈 content above particles */
    }

    /* HERO */
    .hero-section {
        padding-top: 100px;
        padding-bottom: 80px;
    }

    .hero-title {
        font-size: 3rem;
        font-weight: bold;
    }

    .hero-subtitle {
        color: #ccc;
    }

    /* BUTTON */
    .btn-modern {
        background: linear-gradient(45deg,#00c6ff,#0072ff);
        border: none;
        color: white;
        transition: 0.3s;
    }

        .btn-modern:hover {
            transform: translateY(-3px) scale(1.05);
        }

    /* CARDS */
    .feature-card {
        transition: 0.3s;
    }

        .feature-card:hover {
            transform: translateY(-8px) scale(1.03);
            box-shadow: 0 0 25px rgba(0,198,255,0.3);
        }

    /* ICON */
    .icon {
        font-size: 40px;
        margin-bottom: 10px;
    }

    /* ❌ REMOVE OLD UNUSED STUFF */
    .character,
    .box,
    .popup-form {
        display: none;
    }

    /* MOBILE */
    @@media(max - width:768px) {
        .hero-title {
            font-size: 2rem;
        }
    }

</style>